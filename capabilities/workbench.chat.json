  "disabledByDefault": false,
  "verifiedOn": "2026-07-12",
  "action": {
    "name": "workbench-chat",
    "apiShape": "POST /api/v1/ai/request with sourceApp=prism-spectra and intent=workbench-chat",
    "modelMayInfluenceParameters": false,
    "terminalExecution": false,
