{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.local/schemas/ableton-read-only-capability.schema.json",
  "title": "Staged Ableton Read-Only Capability",
  "description": "Inert tool-request manifest for the disabled Ableton read-only adapter. This schema is not loaded by the active Spectra capability registry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "displayName",
    "description",
    "ownerRepo",
    "status",
    "executionMode",
    "entrypoint",
    "locality",
    "dataBoundary",
    "riskClass",
    "approvalRequired",
    "allowedInputs",
    "allowedOutputs",
    "allowedPaths",
    "allowedEnvVars",
    "networkPolicy",
    "credentialPolicy",
    "costPolicy",
    "resourcePolicy",
    "provenanceFields",
    "telemetryFields",
    "validation",
    "rollback",
    "failureMode",
    "disabledByDefault",
    "verifiedOn",
    "gatingContract",
    "action"
  ],
  "properties": {
    "id": {
      "type": "string",
      "enum": [
        "ableton.live.get_version",
        "ableton.live.inspect_selected_track",
        "ableton.live.inspect_device",
        "ableton.live.list_device_parameters"
      ]
    },
    "kind": { "const": "tool-action" },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "ownerRepo": { "const": "prism-spectra" },
    "status": { "const": "disabled" },
    "executionMode": { "const": "read-only" },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "sourceApp", "intent", "adapter"],
      "properties": {
        "type": { "const": "tool-request" },
        "sourceApp": { "const": "ableton-copilot" },
        "intent": {
          "type": "string",
          "enum": [
            "get-live-version",
            "inspect-selected-track",
            "inspect-device",
            "list-device-parameters"
          ]
        },
        "adapter": { "const": "ableton-read-only-bridge-v1" }
      }
    },
    "locality": { "const": "local" },
    "dataBoundary": { "const": "local" },
    "riskClass": { "const": "read-only" },
    "approvalRequired": { "const": false },
    "allowedInputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowedOutputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowedPaths": { "type": "array", "maxItems": 0 },
    "allowedEnvVars": { "type": "array", "maxItems": 0 },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowedHosts"],
      "properties": {
        "mode": { "const": "none" },
        "allowedHosts": { "type": "array", "maxItems": 0 }
      }
    },
    "credentialPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "envVars"],
      "properties": {
        "mode": { "const": "none" },
        "envVars": { "type": "array", "maxItems": 0 }
      }
    },
    "costPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "const": "none" },
        "notes": { "type": "string" }
      }
    },
    "resourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": { "const": "tiny" },
        "notes": { "type": "string" }
      }
    },
    "provenanceFields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "telemetryFields": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tests"],
      "properties": {
        "tests": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "rollback": { "type": "string", "minLength": 1 },
    "failureMode": { "type": "string", "minLength": 1 },
    "disabledByDefault": { "const": true },
    "verifiedOn": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "gatingContract": {
      "const": "prism-beam/docs/contracts/ABLETON_READ_ONLY_CAPABILITY_CONTRACT_2026-07-16.md"
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "apiShape",
        "modelMayInfluenceParameters",
        "terminalExecution",
        "fileWritesPossible",
        "allowedPathRoots",
        "approvalQueueIntegration",
        "checkpointRequired",
        "validationRequired"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "get_live_version",
            "inspect_selected_track",
            "inspect_device_at_path",
            "list_device_parameters"
          ]
        },
        "apiShape": { "type": "string", "minLength": 1 },
        "modelMayInfluenceParameters": { "const": false },
        "terminalExecution": { "const": false },
        "fileWritesPossible": { "const": false },
        "allowedPathRoots": { "type": "array", "maxItems": 0 },
        "approvalQueueIntegration": { "const": "none" },
        "checkpointRequired": { "const": false },
        "validationRequired": { "const": true }
      }
    }
  }
}
