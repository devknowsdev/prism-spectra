{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.local/schemas/spectra-capability-manifest.schema.json",
  "title": "Spectra Capability Manifest",
  "description": "Beam-approved capability manifest vocabulary for Spectra capability registry slice 1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "displayName",
    "description",
    "ownerRepo",
    "status",
    "executionMode",
    "entrypoint",
    "locality",
    "dataBoundary",
    "riskClass",
    "approvalRequired",
    "allowedInputs",
    "allowedOutputs",
    "allowedPaths",
    "allowedEnvVars",
    "networkPolicy",
    "credentialPolicy",
    "costPolicy",
    "resourcePolicy",
    "provenanceFields",
    "telemetryFields",
    "validation",
    "rollback",
    "failureMode",
    "disabledByDefault",
    "verifiedOn"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
    "kind": {
      "type": "string",
      "enum": [
        "model-provider",
        "local-runtime",
        "external-provider-adapter",
        "tool-action",
        "terminal-command",
        "code-assistant-action",
        "sidecar"
      ]
    },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "ownerRepo": { "type": "string", "enum": ["prism-spectra"] },
    "status": { "type": "string", "enum": ["enabled", "disabled", "reserved"] },
    "executionMode": {
      "type": "string",
      "enum": [
        "read-only",
        "propose-write",
        "approved-write",
        "validated-exec",
        "external",
        "destructive"
      ]
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["ai-request", "reserved-domain", "explicit-eval-teacher-dispatch"] },
        "sourceApp": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string", "minLength": 1 }
      }
    },
    "locality": { "type": "string", "enum": ["local", "external", "hybrid"] },
    "dataBoundary": { "type": "string", "enum": ["local", "remote_no_training", "remote_may_train"] },
    "riskClass": {
      "type": "string",
      "enum": [
        "read-only",
        "propose-write",
        "approved-write",
        "validated-exec",
        "external",
        "destructive"
      ]
    },
    "approvalRequired": { "type": "boolean" },
    "allowedInputs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "allowedOutputs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "allowedPaths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "allowedEnvVars": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }, "uniqueItems": true },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowedHosts"],
      "properties": {
        "mode": { "type": "string", "enum": ["none", "loopback-only", "declared-hosts"] },
        "allowedHosts": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "credentialPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "envVars"],
      "properties": {
        "mode": { "type": "string", "enum": ["none", "declared-env"] },
        "envVars": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }, "uniqueItems": true }
      }
    },
    "costPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["none", "visible-before-use"] },
        "notes": { "type": "string" }
      }
    },
    "resourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": { "type": "string", "enum": ["tiny", "small", "medium", "heavy", "extreme"] },
        "notes": { "type": "string" }
      }
    },
    "provenanceFields": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "telemetryFields": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tests"],
      "properties": {
        "tests": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "rollback": { "type": "string", "minLength": 1 },
    "failureMode": { "type": "string", "minLength": 1 },
    "disabledByDefault": { "type": "boolean" },
    "verifiedOn": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "gatingContract": { "type": "string", "minLength": 1 },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "apiShape",
        "modelMayInfluenceParameters",
        "terminalExecution",
        "fileWritesPossible",
        "allowedPathRoots",
        "approvalQueueIntegration",
        "checkpointRequired",
        "validationRequired"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "apiShape": { "type": "string", "minLength": 1 },
        "modelMayInfluenceParameters": { "type": "boolean" },
        "terminalExecution": { "type": "boolean" },
        "fileWritesPossible": { "type": "boolean" },
        "allowedPathRoots": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "approvalQueueIntegration": { "type": "string", "enum": ["none", "required"] },
        "checkpointRequired": { "type": "boolean" },
        "validationRequired": { "type": "boolean" }
      }
    },
    "modelProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roles",
        "contextWindow",
        "speed",
        "qualityTier",
        "costClass",
        "costPerToken",
        "modalities",
        "provider",
        "requiredEnvVar",
        "healthcheck",
        "model",
        "fallbackPolicy"
      ],
      "properties": {
        "roles": {
          "type": "array",
          "items": { "type": "string", "enum": ["teacher", "judge", "persona-driver"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "contextWindow": { "type": "integer", "minimum": 1 },
        "speed": { "type": "string", "enum": ["low", "medium", "high"] },
        "qualityTier": { "type": "string", "enum": ["low", "medium", "high"] },
        "costClass": { "type": "string", "enum": ["free", "metered", "paid"] },
        "costPerToken": {
          "type": "object",
          "additionalProperties": false,
          "required": ["currency", "inputPerMillion", "outputPerMillion"],
          "properties": {
            "currency": { "type": "string", "enum": ["USD"] },
            "inputPerMillion": { "type": "number", "minimum": 0 },
            "outputPerMillion": { "type": "number", "minimum": 0 }
          }
        },
        "modalities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "provider": { "type": "string", "minLength": 1 },
        "requiredEnvVar": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "healthcheck": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "method", "endpoint"],
          "properties": {
            "type": { "type": "string", "enum": ["auth-ping"] },
            "method": { "type": "string", "enum": ["GET"] },
            "endpoint": { "type": "string", "minLength": 1 }
          }
        },
        "model": { "type": "string", "minLength": 1 },
        "fallbackPolicy": { "type": "string", "enum": ["never-normal-routing"] }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "tool-action" } }, "required": ["kind"] },
      "then": { "required": ["action"], "not": { "required": ["modelProvider"] } }
    },
    {
      "if": { "properties": { "kind": { "const": "model-provider" } }, "required": ["kind"] },
      "then": { "required": ["modelProvider"], "not": { "required": ["action"] } }
    }
  ]
}
